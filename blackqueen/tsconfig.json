{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "paths": {
      "@blackqueen/engine": ["./packages/engine/src/index.ts"],
      "@blackqueen/protocol": ["./packages/protocol/src/index.ts"],
      "@twentyeight/engine": ["./packages/engine28/src/index.ts"],
      "@twentyeight/protocol": ["./packages/protocol28/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/test/**/*.ts"],
  "exclude": ["packages/client-react"]
}
